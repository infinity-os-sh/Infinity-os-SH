{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "infinity-os://cloudbase/v1.0/org_capacity.schema.json",
  "collection": "org_capacity",
  "title": "组织产能扩展 (新表/或 users 增列 · 拜访规划只读输入)",
  "_status": "SCAFFOLD · 未上线 · 字段名待字典锁定 · 产能数字=D003_pending",
  "_role": "补 users(组织主数据)缺的『产能』维度:人均日可访店数 + 出发基地坐标。",
  "_dependency": "users 表已有 userCode/userName/role/district;capacity/home 为新增,需后端补。",
  "type": "object",
  "required": ["userCode"],
  "additionalProperties": false,
  "properties": {
    "_id": { "type": "string" },
    "userCode": { "type": "string", "description": "对齐 users.userCode", "examples": ["MG-0420"] },
    "capacityDaily_pending_dict": {
      "type": ["integer", "null"],
      "minimum": 0,
      "default": null,
      "description": "人均日产能上限(可访店数)。null → 引擎用 D003.CAPACITY_DAILY_DEFAULT 占位并标 capacity_default。",
      "_d003": "D003_pending"
    },
    "homeLat_pending_dict": { "type": ["number", "null"], "description": "路线起点纬度" },
    "homeLng_pending_dict": { "type": ["number", "null"], "description": "路线起点经度" },
    "source_ref": { "type": "object", "properties": { "source": { "type": "string" } } }
  },
  "_indexes": [{ "keys": { "userCode": 1 }, "name": "user" }],
  "_guardrail": "只读;产能用于配额,不用于考核。"
}
