{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "infinity-os://cloudbase/v1.0/coverage_blindspot.schema.json",
  "collection": "coverage_blindspot",
  "title": "覆盖盲点 L1-04 (新表 · 拜访规划只读输入)",
  "_status": "SCAFFOLD · 未上线 · 字段名待 bas_field_dictionary_v1_0 锁定(标 *_pending_dict)",
  "_role": "标出系统性失访/从未覆盖的门店,喂给规划引擎的『救火池』。规划只读,不在此判级。",
  "_dependency": "新表,第一回路未建。需后端补。",
  "type": "object",
  "required": ["storeCode", "isBlindspot_pending_dict"],
  "additionalProperties": false,
  "properties": {
    "_id": { "type": "string" },
    "storeCode": { "type": "string", "description": "门店码·对齐 stores.storeCode", "examples": ["SH_GT_CVS_001"] },
    "isBlindspot_pending_dict": { "type": "boolean", "description": "是否盲点(系统性失访/从未覆盖)" },
    "blindReason_pending_dict": {
      "type": "string",
      "enum": ["never_visited", "coverage_gap", "long_overdue", "unassigned", null],
      "description": "盲点成因·喂引擎可解释"
    },
    "detectedAt_pending_dict": { "type": "string", "format": "date-time" },
    "source_ref": { "type": "object", "description": "审计来源·复用第一回路契约", "properties": { "source": { "type": "string" } } }
  },
  "_indexes": [{ "keys": { "storeCode": 1 }, "name": "store" }],
  "_guardrail": "只读输入;本表不含任何拜访完成/打卡态。"
}
