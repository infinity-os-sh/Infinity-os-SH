{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "infinity-os://cloudbase/v1.0/visit_plan.schema.json",
  "collection": "visit_plan",
  "title": "拜访清单+路线 · 规划引擎输出 (新表)",
  "_status": "SCAFFOLD · 未上线 · 字段名待字典锁定(*_pending_dict) · 政策数字 D003_pending",
  "_role": "每人每日『去哪、第几站、为什么』。是 DSR/美顾/督导 app XM(今日任务)的数据源。",
  "_IRON_LAW_1": "本表物理上禁含 visited/checked_in/checkin/who_missed/completion/completed/done/status —— 拜访规划不是打卡考勤。引擎 assertNoAttendance() 会硬性拒绝。",
  "type": "object",
  "required": ["planDate", "userCode", "items", "quota", "generatedAt"],
  "additionalProperties": false,
  "properties": {
    "_id": { "type": "string" },
    "planId_pending_dict": { "type": "string" },
    "planDate": { "type": "string", "format": "date", "description": "清单日期 YYYY-MM-DD" },
    "userCode": { "type": "string", "description": "对齐 users.userCode" },
    "items": {
      "type": "array",
      "description": "排程项·按 seq 即路线顺序",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["storeCode", "seq", "pool", "reasonCode"],
        "properties": {
          "storeCode": { "type": "string" },
          "storeName": { "type": "string" },
          "seq": { "type": "integer", "minimum": 1, "description": "路线顺序" },
          "pool": { "type": "string", "enum": ["fire", "baseline"], "description": "救火 / 常规保底(铁律2)" },
          "reasonCode": { "type": "string", "enum": ["blindspot", "overdue", "regular"], "description": "为什么排·可解释·非考核" },
          "tier": { "type": ["string", "null"], "enum": ["A", "B", "C", null] },
          "tierPending": { "type": "boolean", "description": "true=门店缺分级,按默认频率排(铁律3)" },
          "cycleT": { "type": "integer", "description": "采用的周期T(天)" },
          "daysSinceLast": { "type": ["integer", "null"] },
          "overdueDays": { "type": "integer", "description": "<=0 未逾期" }
        }
      }
    },
    "quota": {
      "type": "object",
      "description": "配额审计(铁律2):证明常规保底没被救火吃光",
      "additionalProperties": false,
      "properties": {
        "capacityDaily": { "type": "integer" },
        "baselineReserved": { "type": "integer", "description": "常规保底名额" },
        "fireCap": { "type": "integer", "description": "救火上限" },
        "usedFire": { "type": "integer" },
        "usedBaseline": { "type": "integer" }
      }
    },
    "humanOverride": {
      "type": "array",
      "description": "经理调整留痕(铁律5)·机器不锁死",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["by", "at"],
        "properties": {
          "by": { "type": "string", "description": "谁改的·对齐 users.userCode" },
          "from": { "type": "array", "items": { "type": "string" }, "description": "原顺序(storeCode 列表)" },
          "to": { "type": "array", "items": { "type": "string" }, "description": "新顺序" },
          "why": { "type": ["string", "null"], "description": "原因" },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source_ref": { "type": "object", "description": "审计来源·复用第一回路契约", "properties": { "source": { "type": "string" }, "app": { "type": "string" } } },
    "flags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "诚实标记·如 D003_pending / tier_pending / capacity_default"
    }
  },
  "_security_rules_hint": {
    "read": "本人读本人清单;经理读本片区。",
    "write": "仅规划引擎(服务端)写;经理调整只能走 humanOverride 留痕,不得静默改 items。",
    "_guardrail": "只排程·不含执行/考勤态·不触发任何涉钱涉权动作。"
  }
}
