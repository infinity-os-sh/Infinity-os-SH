{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "infinity-os://gt-store/v0.1/image-ai-recognition.schema.json",
  "title": "L0 图像 AI 识别采集契约",
  "description": "INF-XD/INF-VL/inventory-v4 拍照识别·喂养 S01/S03/S04/S05 等晶体管·严格按记忆#29三阶段过渡方案",
  "type": "object",
  "required": ["recognition_id", "captured_at", "store_id", "image_url", "model", "stage", "results"],
  "properties": {
    "recognition_id": {"type": "string", "pattern": "^IMG_[0-9]{14}_[A-Z0-9]{6}$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "store_id": {"type": "string"},
    "captured_by": {"type": "string", "description": "拍照人 user_id"},
    "image_url": {"type": "string", "format": "uri"},
    "image_type": {
      "type": "string",
      "enum": ["shelf_panorama", "shelf_section", "price_tag", "second_display", "inventory_stack"],
      "description": "图像类型决定调哪个模型"
    },
    "model": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "enum": ["qianwen_vl", "inventory_v4", "inf_vl", "inf_xd"]},
        "version": {"type": "string", "examples": ["v4.0", "qwen-vl-max-2025"]}
      }
    },
    "stage": {
      "type": "string",
      "enum": ["stage_1_manual", "stage_2_ai_human_verify", "stage_3_ai_default"],
      "description": "记忆#29三阶段·当前默认 stage_1·绝不可'一步到位'AI直接接受"
    },
    "results": {
      "type": "array",
      "description": "识别出的SKU状态·每个SKU一条",
      "items": {
        "type": "object",
        "required": ["sku_id", "confidence", "signals"],
        "properties": {
          "sku_id": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "signals": {
            "type": "object",
            "description": "AI能识别的晶体管子集·主要是 S01/S03/S04/S05",
            "properties": {
              "S01_on_shelf": {"type": "boolean"},
              "S03_main_shelf": {"type": "boolean"},
              "S04_second_display": {"type": "boolean"},
              "S05_price_tag_visible": {"type": "boolean"},
              "S05_price_value": {"type": "number"},
              "facings_count": {"type": "integer", "description": "排面数"},
              "shelf_position": {"type": "string", "enum": ["eye_level", "above_eye", "below_eye", "floor"], "description": "陈列位置"}
            }
          },
          "human_verification": {
            "type": "object",
            "description": "stage_2/3 时人工校验记录·stage_1时为null",
            "properties": {
              "verified": {"type": "boolean"},
              "verified_by": {"type": "string"},
              "corrections": {"type": "object", "description": "人工纠正·喂回模型重训"}
            }
          }
        }
      }
    }
  }
}
