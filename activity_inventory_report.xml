<?xml version="1.0" encoding="utf-8"?>
<!--
    库存上报界面布局
    INFINITY OS · 库存心跳系统 v2.0
    文件：activity_inventory_report.xml
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07080D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- ① 门店信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="① 门店信息"
            android:textColor="#8A95AA"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#141820"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 门店搜索 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="门店名称"
                    android:textColor="#4A5468"
                    android:textSize="11sp"
                    android:paddingBottom="6dp"/>

                <AutoCompleteTextView
                    android:id="@+id/etStoreName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:hint="搜索门店名称…"
                    android:hintTextColor="#3E4A60"
                    android:textColor="#E2E8F4"
                    android:textSize="14sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="text"
                    android:completionThreshold="1"/>

                <!-- 门店等级 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="门店等级"
                    android:textColor="#4A5468"
                    android:textSize="11sp"
                    android:paddingTop="14dp"
                    android:paddingBottom="8dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="2">

                    <Button android:id="@+id/btnGradeSPlus"
                        android:layout_width="0dp" android:layout_columnWeight="1"
                        android:layout_height="60dp" android:layout_margin="3dp"
                        android:text="S+\n旗舰·T=7天" android:textSize="11sp"
                        android:backgroundTint="#1A4A1A" android:textColor="#4ADE80"
                        style="@style/GradeButton"/>
                    <Button android:id="@+id/btnGradeS"
                        android:layout_width="0dp" android:layout_columnWeight="1"
                        android:layout_height="60dp" android:layout_margin="3dp"
                        android:text="S\n重点·T=7天" android:textSize="11sp"
                        android:backgroundTint="#111420" android:textColor="#8A95AA"
                        style="@style/GradeButton"/>
                    <Button android:id="@+id/btnGradeA"
                        android:layout_width="0dp" android:layout_columnWeight="1"
                        android:layout_height="60dp" android:layout_margin="3dp"
                        android:text="A\n重要·T=7天" android:textSize="11sp"
                        android:backgroundTint="#111420" android:textColor="#8A95AA"
                        style="@style/GradeButton"/>
                    <Button android:id="@+id/btnGradeB"
                        android:layout_width="0dp" android:layout_columnWeight="1"
                        android:layout_height="60dp" android:layout_margin="3dp"
                        android:text="B\n标准·T=14天" android:textSize="11sp"
                        android:backgroundTint="#111420" android:textColor="#8A95AA"
                        style="@style/GradeButton"/>
                    <Button android:id="@+id/btnGradeC"
                        android:layout_width="0dp" android:layout_columnWeight="1"
                        android:layout_height="60dp" android:layout_margin="3dp"
                        android:text="C\n普通·T=21天" android:textSize="11sp"
                        android:backgroundTint="#111420" android:textColor="#8A95AA"
                        style="@style/GradeButton"/>
                    <Button android:id="@+id/btnGradeD"
                        android:layout_width="0dp" android:layout_columnWeight="1"
                        android:layout_height="60dp" android:layout_margin="3dp"
                        android:text="D\n基础·T=30天" android:textSize="11sp"
                        android:backgroundTint="#111420" android:textColor="#8A95AA"
                        style="@style/GradeButton"/>
                </GridLayout>

                <!-- SKU选择 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SKU品项"
                    android:textColor="#4A5468"
                    android:textSize="11sp"
                    android:paddingTop="14dp"
                    android:paddingBottom="8dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">
                    <LinearLayout
                        android:id="@+id/skuContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"/>
                </HorizontalScrollView>

                <!-- 日销量a值 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本门店日销量（瓶/天）"
                    android:textColor="#4A5468"
                    android:textSize="11sp"
                    android:paddingTop="14dp"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button android:id="@+id/btnAMinus"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:text="−" android:textSize="20sp"
                        android:backgroundTint="#1A2232" android:textColor="#8A95AA"
                        android:padding="0dp"/>

                    <EditText android:id="@+id/etDailySales"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input"
                        android:text="5" android:textSize="22sp"
                        android:textColor="#E2E8F4" android:gravity="center"
                        android:inputType="numberDecimal"/>

                    <Button android:id="@+id/btnAPlus"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:text="+" android:textSize="20sp"
                        android:backgroundTint="#1A2232" android:textColor="#F5A623"
                        android:padding="0dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ② 库存录入 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="② 库存录入"
            android:textColor="#8A95AA"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#141820"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 货架库存 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 货架库存（瓶）· 品牌领地"
                    android:textColor="#F5A623"
                    android:textSize="12sp"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button android:id="@+id/btnShelfMinus"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:text="−5" android:textSize="14sp"
                        android:backgroundTint="#1A2232" android:textColor="#8A95AA"
                        android:padding="0dp"/>

                    <EditText android:id="@+id/etShelfQty"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input"
                        android:text="0" android:textSize="26sp"
                        android:textStyle="bold" android:textColor="#E2E8F4"
                        android:gravity="center" android:inputType="number"/>

                    <Button android:id="@+id/btnShelfPlus"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:text="+5" android:textSize="14sp"
                        android:backgroundTint="#1A2232" android:textColor="#F5A623"
                        android:padding="0dp"/>
                </LinearLayout>

                <!-- 分割线 -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1A2232" android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"/>

                <!-- 仓库库存 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏪 仓库库存（箱）· 后备库存"
                    android:textColor="#4ECDC4"
                    android:textSize="12sp"
                    android:paddingBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button android:id="@+id/btnWarehouseMinus"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:text="−" android:textSize="20sp"
                        android:backgroundTint="#1A2232" android:textColor="#8A95AA"
                        android:padding="0dp"/>

                    <EditText android:id="@+id/etWarehouseQty"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input"
                        android:text="0" android:textSize="26sp"
                        android:textStyle="bold" android:textColor="#E2E8F4"
                        android:gravity="center" android:inputType="number"/>

                    <Button android:id="@+id/btnWarehousePlus"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:text="+" android:textSize="20sp"
                        android:backgroundTint="#1A2232" android:textColor="#4ECDC4"
                        android:padding="0dp"/>
                </LinearLayout>

                <!-- 每箱瓶数 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#0F1219"
                    android:padding="10dp"
                    android:layout_marginTop="8dp">

                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="每箱换算"
                        android:textColor="#4A5468" android:textSize="11sp"/>

                    <Spinner android:id="@+id/spinnerPerCase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E2E8F4"/>

                    <TextView android:id="@+id/tvWarehouseBottles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="= 0瓶"
                        android:textColor="#F5A623"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ③ 心跳水位 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="③ 心跳水位诊断"
            android:textColor="#8A95AA"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardWaterLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#141820"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="当前库存水位"
                        android:textColor="#4A5468" android:textSize="11sp"/>

                    <TextView android:id="@+id/tvWaterBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="等待录入"
                        android:textColor="#4A5468" android:textSize="11sp"
                        android:background="@drawable/bg_badge_empty"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tvWaterLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#3E4A60"
                    android:textSize="48sp"
                    android:textStyle="bold"/>

                <TextView android:id="@+id/tvWaterSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="请填写库存数量"
                    android:textColor="#4A5468" android:textSize="12sp"
                    android:paddingBottom="12dp"/>

                <!-- 三格水位条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <View android:id="@+id/wbDanger"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="8dp" android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_water_bar"/>
                    <View android:id="@+id/wbWarning"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="8dp" android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_water_bar"/>
                    <View android:id="@+id/wbSafe"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_water_bar"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp" android:paddingBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="危险 <1a" android:textColor="#4A5468" android:textSize="9sp"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="预警 1-2a" android:textColor="#4A5468"
                        android:textSize="9sp" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="安全 >2a" android:textColor="#4A5468"
                        android:textSize="9sp" android:gravity="end"/>
                </LinearLayout>

                <!-- 公式详情 -->
                <TextView android:id="@+id/tvFormula"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="录入数据后显示计算过程"
                    android:textColor="#4A5468" android:textSize="11sp"
                    android:fontFamily="monospace" android:lineSpacingMultiplier="1.6"
                    android:background="#0F1219" android:padding="12dp"/>

                <!-- 补货建议 -->
                <TextView android:id="@+id/tvAdvice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:textSize="13sp" android:textColor="#8A95AA"
                    android:lineSpacingMultiplier="1.5"
                    android:padding="12dp" android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ④ 拍照记录 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="④ 拍照记录"
            android:textColor="#8A95AA"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#141820"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Button android:id="@+id/btnTakePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:text="📷  拍摄货架照片"
                    android:textSize="16sp" android:textColor="#8A95AA"
                    android:backgroundTint="#0F1219"
                    android:drawablePadding="8dp"/>

                <ImageView android:id="@+id/ivPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:visibility="gone"
                    android:scaleType="centerCrop"/>

                <Button android:id="@+id/btnRedoPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重拍"
                    android:visibility="gone"
                    android:backgroundTint="#1A2232"
                    android:textColor="#8A95AA"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ⑤ 异常标记 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⑤ 异常标记（可选）"
            android:textColor="#8A95AA"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#141820"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <CheckBox android:id="@+id/cbFlagA"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="库存明显偏高，怀疑压货（A类失真）"
                    android:textColor="#8A95AA" android:textSize="12sp"
                    android:buttonTint="#FF5F5F"/>

                <CheckBox android:id="@+id/cbFlagB"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="促销期间数据，非正常销售（B类失真）"
                    android:textColor="#8A95AA" android:textSize="12sp"
                    android:buttonTint="#F5A623"/>

                <CheckBox android:id="@+id/cbFlagC"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="发现低价/窜货商品（C类失真）"
                    android:textColor="#8A95AA" android:textSize="12sp"
                    android:buttonTint="#60A5FA"/>

                <EditText android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_input"
                    android:hint="备注：其他异常、陈列问题、竞品动态…"
                    android:hintTextColor="#3E4A60"
                    android:textColor="#E2E8F4" android:textSize="13sp"
                    android:padding="12dp" android:gravity="top"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
